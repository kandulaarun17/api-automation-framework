<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">

	<Appenders>

		<Console name="Console">
			<PatternLayout pattern="%d{HH:mm:ss} %-5level %c - %msg%n" />
		</Console>

		<File name="File"
			fileName="logs/APIAutomation.log"
			append="true">

			<PatternLayout pattern="%d %-5level %c - %msg%n" />

		</File>

	</Appenders>

	<Loggers>

		<Root level="info">
			<AppenderRef ref="Console" />
			<AppenderRef ref="File" />
		</Root>

	</Loggers>

</Configuration>